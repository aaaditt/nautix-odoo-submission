<odoo>
    <!-- Tree View -->
    <record id="nautix_model_view_tree" model="ir.ui.view">
        <field name="name">nautix.model.tree</field>
        <field name="model">nautix.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="nautix_model_view_form" model="ir.ui.view">
        <field name="name">nautix.model.form</field>
        <field name="model">nautix.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="nautix_model_action" model="ir.actions.act_window">
        <field name="name">Nautix</field>
        <field name="res_model">nautix.model</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
